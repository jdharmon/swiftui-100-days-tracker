{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "next dev",
            "type": "npm",
            "script": "dev",
            "isBackground": true,
            "problemMatcher": {
                "owner": "next",
                "pattern": {
                    "regexp": "^(.+):(\\d+):(\\d+):\\s+(.+)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "message": 4
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "\\$\\s+next dev",
                    "endsPattern": "Local:\\s+http"
                }
            }
        }
    ]
}
